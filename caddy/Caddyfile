{
    on_demand_tls {
        ask http://nginx:80/internal/domain-check?token={$DOMAIN_CHECK_TOKEN}
        interval 2m
        burst 5
    }
}

# Local central + tenant domains
app.localhost, *.app.localhost {
    tls internal
    reverse_proxy nginx:80
}

# Keep local HTTP available too
http://app.localhost, http://*.app.localhost {
    reverse_proxy nginx:80
}

# Fallback origin for Cloudflare Custom Hostnames
proxy-fallback.bhonewai.cc.cd {
    tls internal
    reverse_proxy nginx:80
}

# Custom domains
:443 {
    tls {
        issuer internal
        on_demand
    }
    reverse_proxy nginx:80
}

:80 {
    redir https://{host}{uri} permanent
}
