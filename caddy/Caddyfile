{
    on_demand_tls {
        ask http://nginx:80/internal/domain-check?token={$DOMAIN_CHECK_TOKEN}
        interval 2m
        burst 5
    }
}

# Local central domains (dev certs)
app.localhost, *.app.localhost {
    tls internal
    reverse_proxy nginx:80
}

# Custom domains (public)
:443 {
    tls {
        on_demand
    }
    reverse_proxy nginx:80
}

:80 {
    redir https://{host}{uri} permanent
}
