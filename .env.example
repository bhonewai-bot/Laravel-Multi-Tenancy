APP_NAME=Multi-tenancy
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://app.localhost
TENANCY_CENTRAL_DOMAIN=app.localhost
TENANT_DEFAULT_ADMIN_PASSWORD=ChangeMe123!
CENTRAL_SUPERADMIN_EMAIL=superadmin@example.com
CENTRAL_SUPERADMIN_NAME='Super Admin'
CENTRAL_SUPERADMIN_PASSWORD=password
DOMAIN_CHECK_TOKEN=change-me-long-random-token

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_DAILY_DAYS=30
OPS_ALERT_SLACK_WEBHOOK_URL=

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue
QUEUE_CONNECTION=database
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=180
QUEUE_FAILED_DRIVER=database-uuids

# Worker runtime defaults
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_BACKOFF=10
QUEUE_WORKER_TIMEOUT=120
QUEUE_WORKER_SLEEP=3
QUEUE_WORKER_MAX_TIME=3600

# Tenancy provisioning queue toggle
TENANCY_PROVISIONING_QUEUE=false

# Telescope (dev/internal)
TELESCOPE_ENABLED=false
TELESCOPE_DOMAIN=
TELESCOPE_PATH=telescope
TELESCOPE_ALLOWED_EMAILS=superadmin@example.com

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Cloudflare Custom Hostnames
CLOUDFLARE_ENABLED=false
CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_FALLBACK_ORIGIN=app.example.com
CLOUDFLARE_VALIDATION_METHOD=http
CLOUDFLARE_TIMEOUT=15
CLOUDFLARE_RETRY_TIMES=2
CLOUDFLARE_RETRY_SLEEP_MS=200
